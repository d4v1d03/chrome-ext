# ── AI ────────────────────────────────────────────────────────────────────────
# Required for AI Summary mode
OPENAI_API_KEY=sk-...

# ── Celery / Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Encryption ────────────────────────────────────────────────────────────────
# Change this to a random 32+ char string before going to production
ENCRYPTION_SECRET=change-me-in-production-32chars!

# ── Filecoin (optional) ───────────────────────────────────────────────────────
# Leave blank to use MockStorage (good for development)
FILECOIN_PRIVATE_KEY=
FILECOIN_NETWORK=calibration

# ── API Auth (optional) ───────────────────────────────────────────────────────
# If set, all API requests must include X-API-Key: <value>
BACKEND_API_KEY=
